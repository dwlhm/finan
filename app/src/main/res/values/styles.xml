<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Finan.Text.Title" parent="TextAppearance.AppCompat.Title">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/finan_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Finan.Text.Body" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/finan_text_primary</item>
    </style>

    <style name="Finan.Text.Amount" parent="TextAppearance.AppCompat.Headline">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/finan_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Finan.Button.Primary" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Finan.Button.Nav" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:textColor">@color/finan_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">40dp</item>
    </style>
</resources>
