<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Finan.Text.Title" parent="TextAppearance.AppCompat.Title">
        <item name="android:textSize">22sp</item>
        <item name="android:textColor">@color/finan_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Finan.Text.Body" parent="TextAppearance.AppCompat.Body1">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/finan_text_primary</item>
    </style>

    <style name="Finan.Text.Amount" parent="TextAppearance.AppCompat.Headline">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/finan_text_primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Finan.Text.SectionLabel" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textColor">@color/finan_text_secondary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Finan.Text.CollapsibleLabel" parent="TextAppearance.AppCompat.Body2">
        <item name="android:textColor">@color/finan_text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Finan.Panel.Emphasis" parent="@android:style/Widget">
        <item name="android:background">@drawable/bg_panel_emphasis</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:paddingBottom">16dp</item>
    </style>

    <style name="Finan.Panel.Section" parent="@android:style/Widget">
        <item name="android:background">@drawable/bg_card</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">14dp</item>
    </style>

    <style name="Finan.Panel.CollapsibleContent" parent="@android:style/Widget">
        <item name="android:background">@drawable/bg_control_surface</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="Finan.Control.Surface" parent="@android:style/Widget">
        <item name="android:background">@drawable/bg_control_surface</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">10dp</item>
        <item name="android:paddingEnd">10dp</item>
    </style>

    <style name="Finan.Control.RadioGroup" parent="@android:style/Widget">
        <item name="android:background">@drawable/bg_control_surface</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">8dp</item>
        <item name="android:paddingEnd">8dp</item>
    </style>

    <style name="Finan.Control.RadioButton" parent="Widget.AppCompat.CompoundButton.RadioButton">
        <item name="android:minHeight">48dp</item>
        <item name="android:textColor">@color/finan_text_primary</item>
    </style>

    <style name="Finan.Control.CollapsibleToggle" parent="@android:style/Widget">
        <item name="android:background">@drawable/bg_control_surface</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="android:gravity">center_vertical</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
    </style>

    <style name="Finan.Icon.ControlIndicator" parent="@android:style/Widget">
        <item name="android:layout_width">24dp</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:importantForAccessibility">no</item>
        <item name="android:tint">@color/finan_primary</item>
    </style>

    <style name="Finan.EditText.Transparent" parent="Widget.AppCompat.EditText">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:importantForAutofill">no</item>
    </style>

    <style name="Finan.Button.Primary" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="Finan.Button.Nav" parent="Widget.AppCompat.Button.Borderless">
        <item name="android:textColor">@color/finan_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">40dp</item>
    </style>

    <style name="Finan.Button.Select" parent="Finan.Button.Nav">
        <item name="android:background">@drawable/bg_control_surface</item>
        <item name="android:gravity">start|center_vertical</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:paddingStart">12dp</item>
        <item name="android:paddingEnd">12dp</item>
    </style>

    <style name="Finan.BottomNavItem" parent="@android:style/Widget">
        <item name="android:background">@drawable/bg_bottom_nav_item</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackgroundBorderless</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:paddingTop">5dp</item>
        <item name="android:paddingBottom">4dp</item>
    </style>

    <style name="Finan.BottomNavIcon" parent="@android:style/Widget">
        <item name="android:layout_width">21dp</item>
        <item name="android:layout_height">21dp</item>
        <item name="android:duplicateParentState">true</item>
        <item name="android:importantForAccessibility">no</item>
        <item name="android:tint">@color/bottom_nav_icon</item>
    </style>

    <style name="Finan.Text.BottomNavLabel" parent="TextAppearance.AppCompat.Caption">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">1dp</item>
        <item name="android:duplicateParentState">true</item>
        <item name="android:gravity">center</item>
        <item name="android:importantForAccessibility">no</item>
        <item name="android:includeFontPadding">false</item>
        <item name="android:maxLines">1</item>
        <item name="android:paddingStart">2dp</item>
        <item name="android:paddingEnd">2dp</item>
        <item name="android:textColor">@color/bottom_nav_text</item>
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:autoSizeTextType">uniform</item>
        <item name="android:autoSizeMinTextSize">9sp</item>
        <item name="android:autoSizeMaxTextSize">11sp</item>
        <item name="android:autoSizeStepGranularity">1sp</item>
    </style>
</resources>
