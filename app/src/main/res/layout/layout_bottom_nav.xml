<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/bottom_nav"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_nav"
    android:elevation="4dp"
    android:orientation="horizontal"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <Button
        android:id="@+id/nav_capture"
        style="@style/Finan.Button.Nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/nav_capture" />

    <Button
        android:id="@+id/nav_history"
        style="@style/Finan.Button.Nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/nav_history" />

    <Button
        android:id="@+id/nav_summary"
        style="@style/Finan.Button.Nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/nav_summary" />

    <Button
        android:id="@+id/nav_wallet"
        style="@style/Finan.Button.Nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/nav_wallet" />

    <Button
        android:id="@+id/nav_settings"
        style="@style/Finan.Button.Nav"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:text="@string/nav_settings" />
</LinearLayout>
