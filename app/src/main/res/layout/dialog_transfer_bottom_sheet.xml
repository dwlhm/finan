<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingEnd="20dp"
    android:paddingTop="12dp"
    android:paddingBottom="20dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="12dp"
        android:background="@drawable/bg_bottom_sheet_handle" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/wallet_transfer_dialog_title"
                android:textAppearance="@style/Finan.Text.Title" />

            <TextView
                style="@style/Finan.Text.SectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/wallet_transfer_source_label" />

            <Spinner
                android:id="@+id/wallet_transfer_source"
                style="@style/Finan.Control.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <TextView
                style="@style/Finan.Text.SectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/wallet_transfer_destination_label" />

            <Spinner
                android:id="@+id/wallet_transfer_destination"
                style="@style/Finan.Control.Surface"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp" />

            <com.dwlhm.finan.ui.common.LabeledEditTextView
                android:id="@+id/wallet_transfer_amount_field"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:inputType="numberDecimal"
                app:fieldHint="@string/capture_amount_placeholder"
                app:labelText="@string/transaction_amount_label" />

            <include
                layout="@layout/include_transaction_occurred_at"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp" />

            <TextView
                style="@style/Finan.Text.SectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/transaction_note_label" />

            <EditText
                android:id="@+id/wallet_transfer_note"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_control_surface"
                android:hint="@string/capture_note_hint"
                android:importantForAutofill="no"
                android:inputType="textCapSentences|textMultiLine"
                android:minHeight="64dp"
                android:padding="12dp"
                android:textColor="@color/finan_text_primary"
                android:textColorHint="@color/finan_text_hint" />

            <com.dwlhm.finan.ui.common.DialogActionsView
                android:id="@+id/wallet_transfer_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:primaryText="@string/wallet_transfer_save" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>
