<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="48dp"
    android:background="@drawable/bg_control_surface"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="12dp"
    android:paddingEnd="12dp">

    <TextView
        android:id="@+id/item_category_section"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textColor="@color/finan_text_primary"
        android:textSize="14sp"
        android:textStyle="bold" />

    <ImageView
        android:id="@+id/item_category_section_indicator"
        style="@style/Finan.Icon.ControlIndicator"
        android:importantForAccessibility="no" />
</LinearLayout>
