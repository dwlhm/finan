<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/finan_background"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingTop="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="4dp"
        android:text="@string/history_title"
        android:textAppearance="@style/Finan.Text.Title" />

    <TextView
        android:id="@+id/history_count"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:textColor="@color/finan_text_secondary"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/history_controls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/history_date_range"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:background="@drawable/bg_control_surface"
            android:clickable="true"
            android:contentDescription="@string/history_date_range_content_description"
            android:drawableStart="@drawable/ic_summary_calendar"
            android:drawablePadding="6dp"
            android:ellipsize="end"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/finan_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/history_filter_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_control_surface"
            android:contentDescription="@string/history_filter_content_description"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:scaleType="center"
            android:src="@drawable/ic_summary_filter" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/history_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_card"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="14dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/Finan.Text.SectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/history_transactions_label" />

            <TextView
                android:id="@+id/history_total_transactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:includeFontPadding="false"
                android:textColor="@color/finan_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="42dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@color/finan_divider" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.35"
            android:orientation="vertical">

            <TextView
                style="@style/Finan.Text.SectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/history_income_label" />

            <TextView
                android:id="@+id/history_income_total"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:autoSizeMaxTextSize="17sp"
                android:autoSizeMinTextSize="11sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/finan_income"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="42dp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:background="@color/finan_divider" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.35"
            android:orientation="vertical">

            <TextView
                style="@style/Finan.Text.SectionLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/history_expense_label" />

            <TextView
                android:id="@+id/history_expense_total"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:autoSizeMaxTextSize="17sp"
                android:autoSizeMinTextSize="11sp"
                android:autoSizeStepGranularity="1sp"
                android:autoSizeTextType="uniform"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:textColor="@color/finan_expense"
                android:textSize="17sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <com.dwlhm.finan.ui.common.infinitescroll.InfiniteScrollListView
        android:id="@+id/history_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        app:infiniteScrollItemSpacing="8dp"
        app:infiniteScrollLoadThreshold="5"
        app:infiniteScrollPageSize="30" />

    <LinearLayout
        android:id="@+id/history_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_card"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/history_empty"
            android:textColor="@color/finan_text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="@string/history_empty_hint"
            android:textColor="@color/finan_text_secondary"
            android:textSize="14sp" />
    </LinearLayout>
</LinearLayout>
