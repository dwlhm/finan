<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/finan_background"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="@string/wallet_title"
        android:textAppearance="@style/Finan.Text.Title" />

    <ListView
        android:id="@+id/wallet_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@color/finan_divider"
        android:dividerHeight="1dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp" />

    <TextView
        android:id="@+id/wallet_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="@string/wallet_empty"
        android:textColor="@color/finan_text_hint"
        android:visibility="gone" />

    <include layout="@layout/layout_bottom_nav" />
</LinearLayout>
