<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/finan_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Top Toggle -->
    <LinearLayout
        android:id="@+id/capture_type_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_control_surface"
        android:orientation="horizontal"
        android:padding="4dp">

        <TextView
            android:id="@+id/capture_type_expense"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="@drawable/bg_chip_selected"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:paddingVertical="12dp"
            android:text="↓ Expense"
            android:textColor="@color/finan_text_primary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/capture_type_income"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:paddingVertical="12dp"
            android:text="↑ Income"
            android:textColor="@color/finan_text_secondary"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/capture_type_transfer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:paddingHorizontal="8dp"
            android:paddingVertical="12dp"
            android:text="⇄ Transfer"
            android:textColor="@color/finan_text_secondary"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Main Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_card"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Amount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="bottom"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="4dp"
                android:layout_marginBottom="8dp"
                android:text="Rp"
                android:textColor="@color/finan_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/capture_amount"
                style="@style/Finan.EditText.Transparent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="0"
                android:importantForAutofill="no"
                android:inputType="numberDecimal"
                android:padding="0dp"
                android:textColor="@color/finan_text_primary"
                android:textSize="48sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Details Sentence -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/capture_sentence_for"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="for "
                android:textColor="@color/finan_text_secondary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/capture_category_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:padding="4dp"
                android:text="#Category"
                android:textColor="@color/finan_warm_accent"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/capture_sentence_from"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" from "
                android:textColor="@color/finan_text_secondary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/capture_wallet_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:padding="4dp"
                android:drawableStart="@drawable/ic_wallet"
                android:drawablePadding="4dp"
                android:drawableTint="@color/finan_primary"
                android:text="Wallet"
                android:textColor="@color/finan_primary"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Date & Note -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/capture_date_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?android:attr/selectableItemBackground"
                android:padding="4dp"
                android:text="\@Now"
                android:textColor="@color/finan_text_secondary"
                android:textSize="16sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/capture_note"
                style="@style/Finan.EditText.Transparent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:hint="add note..."
                android:importantForAutofill="no"
                android:inputType="textCapSentences"
                android:padding="4dp"
                android:textColorHint="@color/finan_text_hint"
                android:textSize="16sp"
                android:textStyle="italic" />
        </LinearLayout>

        <TextView
            android:id="@+id/capture_validation_banner"
            style="@style/Finan.Text.FieldError"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_panel_emphasis_error"
            android:drawableStart="@drawable/ic_error"
            android:drawablePadding="8dp"
            android:padding="8dp"
            android:gravity="center_vertical"
            android:text="@string/capture_validation_hint"
            android:visibility="gone" />
    </LinearLayout>
    


    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <com.dwlhm.finan.ui.components.FinancialKeypadView
        android:id="@+id/capture_financial_keypad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/capture_save"
        style="@style/Finan.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="24dp"
        android:text="Record Transaction"
        android:textSize="18sp"
        android:textStyle="bold" />

</LinearLayout>
