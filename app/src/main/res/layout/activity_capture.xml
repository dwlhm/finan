<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/finan_background"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textAppearance="@style/Finan.Text.Title" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common_currency_prefix"
                    android:textColor="@color/finan_text_secondary"
                    android:textSize="14sp" />

                <EditText
                    android:id="@+id/capture_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="@string/capture_amount_hint"
                    android:importantForAutofill="no"
                    android:inputType="numberDecimal"
                    android:textAppearance="@style/Finan.Text.Amount" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/capture_type_label"
                android:textColor="@color/finan_text_secondary"
                android:textSize="14sp" />

            <RadioGroup
                android:id="@+id/capture_type_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/capture_type_expense"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/capture_type_expense" />

                <RadioButton
                    android:id="@+id/capture_type_income"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/capture_type_income" />
            </RadioGroup>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/capture_wallet_label"
                android:textColor="@color/finan_text_secondary"
                android:textSize="14sp" />

            <Spinner
                android:id="@+id/capture_wallet_spinner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card"
                android:minHeight="48dp"
                android:padding="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/capture_category_label"
                android:textColor="@color/finan_text_secondary"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/capture_quick_categories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal" />

            <Button
                android:id="@+id/capture_category_more"
                style="@style/Finan.Button.Nav"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card"
                android:gravity="start|center_vertical"
                android:minHeight="48dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/capture_category_more" />

            <Button
                android:id="@+id/capture_details_toggle"
                style="@style/Finan.Button.Nav"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/capture_details_toggle" />

            <LinearLayout
                android:id="@+id/capture_details_panel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_card"
                android:orientation="vertical"
                android:padding="12dp"
                android:visibility="gone">

                <EditText
                    android:id="@+id/capture_note"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/capture_note_hint"
                    android:importantForAutofill="no"
                    android:inputType="textCapSentences" />
            </LinearLayout>

            <Button
                android:id="@+id/capture_save"
                style="@style/Finan.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/capture_save" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="@string/capture_recent_label"
                android:textColor="@color/finan_text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ListView
                android:id="@+id/capture_recent_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:divider="@color/finan_divider"
                android:dividerHeight="1dp"
                android:nestedScrollingEnabled="true" />

            <TextView
                android:id="@+id/capture_recent_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/capture_recent_empty"
                android:textColor="@color/finan_text_hint"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/layout_bottom_nav" />
</LinearLayout>
