<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <ScrollView
        android:id="@+id/capture_scroll"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

                <LinearLayout
                    android:id="@+id/capture_amount_section"
                    style="@style/Finan.Panel.Emphasis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/capture_amount_label"
                            android:textColor="@color/finan_warm_accent"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            style="@style/Finan.Text.RequiredMarker"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/capture_amount"
                        style="@style/Finan.EditText.Transparent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:hint="@string/capture_amount_placeholder"
                        android:importantForAutofill="no"
                        android:inputType="numberDecimal"
                        android:textAppearance="@style/Finan.Text.Amount" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <HorizontalScrollView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:fillViewport="false"
                            android:overScrollMode="never"
                            android:scrollbars="none">

                            <LinearLayout
                                android:id="@+id/capture_amount_shortcuts"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal" />
                        </HorizontalScrollView>

                        <ImageButton
                            android:id="@+id/capture_amount_shortcuts_edit"
                            android:layout_width="34dp"
                            android:layout_height="34dp"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_chip"
                            android:contentDescription="@string/capture_amount_shortcuts_edit_content_description"
                            android:padding="5dp"
                            android:scaleType="center"
                            android:src="@drawable/ic_edit"
                            app:tint="@color/finan_text_primary" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/capture_amount_error"
                        style="@style/Finan.Text.FieldError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    style="@style/Finan.Panel.Section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp">

                    <TextView
                        style="@style/Finan.Text.SectionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/capture_type_label" />

                    <RadioGroup
                        android:id="@+id/capture_type_group"
                        style="@style/Finan.Control.RadioGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">

                        <RadioButton
                            android:id="@+id/capture_type_expense"
                            style="@style/Finan.Control.RadioButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="@color/radio_expense_tint"
                            android:checked="true"
                            android:text="@string/capture_type_expense" />

                        <RadioButton
                            android:id="@+id/capture_type_income"
                            style="@style/Finan.Control.RadioButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:buttonTint="@color/radio_income_tint"
                            android:text="@string/capture_type_income" />

                        <RadioButton
                            android:id="@+id/capture_type_transfer"
                            style="@style/Finan.Control.RadioButton"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/capture_type_transfer" />
                    </RadioGroup>

                    <LinearLayout
                        android:id="@+id/capture_wallet_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical"
                        android:padding="2dp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/capture_wallet_label"
                                style="@style/Finan.Text.SectionLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/capture_wallet_label" />

                            <TextView
                                style="@style/Finan.Text.RequiredMarker"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <Spinner
                            android:id="@+id/capture_wallet_spinner"
                            style="@style/Finan.Control.Surface"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:id="@+id/capture_wallet_error"
                            style="@style/Finan.Text.FieldError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/capture_destination_section"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:orientation="vertical"
                        android:padding="2dp"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                style="@style/Finan.Text.SectionLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/wallet_transfer_destination_label" />

                            <TextView
                                style="@style/Finan.Text.RequiredMarker"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content" />
                        </LinearLayout>

                        <Spinner
                            android:id="@+id/capture_destination_spinner"
                            style="@style/Finan.Control.Surface"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp" />

                        <TextView
                            android:id="@+id/capture_destination_error"
                            style="@style/Finan.Text.FieldError"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="6dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/capture_category_section"
                    style="@style/Finan.Panel.Section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            style="@style/Finan.Text.SectionLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/capture_category_label" />

                        <TextView
                            style="@style/Finan.Text.RequiredMarker"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/capture_category_controls"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:padding="2dp">

                        <HorizontalScrollView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:fillViewport="false"
                            android:overScrollMode="never"
                            android:scrollbars="none">

                            <LinearLayout
                                android:id="@+id/capture_quick_categories"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal" />
                        </HorizontalScrollView>

                        <Button
                            android:id="@+id/capture_category_more"
                            style="@style/Finan.Button.Select"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="@string/capture_category_more" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/capture_category_error"
                        style="@style/Finan.Text.FieldError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:visibility="gone" />
                </LinearLayout>

                <LinearLayout
                    style="@style/Finan.Panel.Section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            style="@style/Finan.Text.SectionLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/transaction_datetime_label" />

                        <TextView
                            style="@style/Finan.Text.RequiredMarker"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content" />
                    </LinearLayout>

                    <include layout="@layout/include_transaction_occurred_at_fields" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/capture_details_toggle"
                    style="@style/Finan.Control.CollapsibleToggle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp">

                    <TextView
                        style="@style/Finan.Text.CollapsibleLabel"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/capture_details_toggle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="@string/label_optional_hint"
                        android:textColor="@color/finan_text_hint"
                        android:textSize="12sp" />

                    <ImageView
                        android:id="@+id/capture_details_chevron"
                        style="@style/Finan.Icon.ControlIndicator"
                        android:layout_marginStart="8dp"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_expand_more" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/capture_details_panel"
                    style="@style/Finan.Panel.CollapsibleContent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:visibility="gone">

                    <EditText
                        android:id="@+id/capture_note"
                        style="@style/Finan.EditText.Transparent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/capture_note_hint"
                        android:importantForAutofill="no"
                        android:inputType="textCapSentences" />

                    <LinearLayout
                        android:id="@+id/capture_transaction_metadata_fields"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <include layout="@layout/include_transaction_tags_merchant_fields" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/capture_validation_banner"
                    style="@style/Finan.Text.FieldError"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="@string/capture_validation_hint"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/capture_save"
                    style="@style/Finan.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/capture_save" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="@string/capture_recent_label"
                    android:textColor="@color/finan_text_secondary"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/capture_recent_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/capture_recent_empty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center"
                    android:text="@string/capture_recent_empty"
                    android:textColor="@color/finan_text_hint"
                    android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/capture_undo_bar"
        style="@style/Finan.Panel.Section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <TextView
            android:id="@+id/capture_undo_message"
            style="@style/Finan.Text.Body"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/capture_saved_undo_message" />

        <Button
            android:id="@+id/capture_undo_action"
            style="@style/Finan.Button.Nav"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:text="@string/capture_undo_action" />
    </LinearLayout>
</LinearLayout>
