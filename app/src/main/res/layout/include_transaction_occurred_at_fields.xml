<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="8dp"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/transaction_occurred_date"
        style="@style/Finan.Control.OccurredAtValue"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:contentDescription="@string/transaction_date_picker_title"
        app:drawableStartCompat="@drawable/ic_summary_calendar" />

    <TextView
        android:id="@+id/transaction_occurred_time"
        style="@style/Finan.Control.OccurredAtValue"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:contentDescription="@string/transaction_time_picker_title"
        app:drawableStartCompat="@drawable/ic_schedule" />
</LinearLayout>
