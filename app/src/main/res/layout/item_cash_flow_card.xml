<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:layout_marginTop="14dp"
    android:padding="16dp">

    <!-- Header: Activity Title and Net flow -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/item_cashflow_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/finan_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/item_cashflow_net"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/finan_primary"
            android:textSize="16sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Subtitle/Details: Inflow and Outflow -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/item_cashflow_inflow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="@color/finan_text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/item_cashflow_outflow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/finan_text_secondary"
            android:textSize="12sp" />
    </LinearLayout>

    <View
        android:id="@+id/item_cashflow_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="@color/finan_divider" />

    <!-- Direct horizontal chart and legend layout -->
    <LinearLayout
        android:id="@+id/item_cashflow_chart_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="12dp"
        android:paddingVertical="8dp">

        <com.dwlhm.finan.ui.components.DonutChartView
            android:id="@+id/item_cashflow_donut_chart"
            android:layout_width="130dp"
            android:layout_height="130dp" />

        <LinearLayout
            android:id="@+id/item_cashflow_chart_legend"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="20dp"
            android:orientation="vertical" />
    </LinearLayout>
</LinearLayout>
