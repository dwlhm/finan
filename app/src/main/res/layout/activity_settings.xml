<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:text="@string/settings_title"
        android:textAppearance="@style/Finan.Text.Title" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/settings_export"
            style="@style/Finan.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_export" />

        <ProgressBar
            android:id="@+id/settings_export_progress"
            style="?android:attr/progressBarStyleSmall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="12dp"
            android:indeterminate="true"
            android:visibility="gone" />

        <TextView
            android:id="@+id/settings_export_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center_horizontal"
            android:text="@string/settings_export_in_progress"
            android:textColor="@color/finan_text_secondary"
            android:textSize="14sp"
            android:visibility="gone" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/settings_export_hint"
            android:textColor="@color/finan_text_secondary"
            android:textSize="14sp" />

        <Button
            android:id="@+id/settings_wallets"
            style="@style/Finan.Button.Nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:text="@string/settings_manage_wallets" />

        <Button
            android:id="@+id/settings_categories"
            style="@style/Finan.Button.Nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_card"
            android:padding="12dp"
            android:text="@string/settings_manage_categories" />
    </LinearLayout>
</LinearLayout>
